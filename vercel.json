{
  "version": 2,
  "rewrites": [
    { "source": "/player/:id", "destination": "/player.html?id=:id" },
    { "source": "/team/:id", "destination": "/team.html?id=:id" },
    { "source": "/league/:id", "destination": "/competition.html?id=:id" },
    { "source": "/standings/:id", "destination": "/competition.html?id=:id" },
    { "source": "/search", "destination": "/search.html" },
    { "source": "/match/:id", "destination": "/match.html?id=:id" },
    { "source": "/api/:path*", "destination": "https://sportylytics.onrender.com/:path*" },
    { "source": "/", "destination": "/index.html" }
  ]
}
